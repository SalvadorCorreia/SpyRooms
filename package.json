{
  "name": "spyrooms",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter @spyrooms/client dev",
    "dev:server": "pnpm --filter @spyrooms/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  }
}
